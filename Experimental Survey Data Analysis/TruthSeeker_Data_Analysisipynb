   "source": [
    "condition_comparison = comparison[[\n",
    "    'Participation Id',\n",
    "    'latent_mean_llm', 'latent_mean_truthseeker',\n",
    "    'recent_mean_llm', 'recent_mean_truthseeker',\n",
    "    'new_mean_llm', 'new_mean_truthseeker',\n",
    "]].copy()\n",
    "\n",
    "for metric in ['latent_mean', 'recent_mean', 'new_mean']:\n",
    "    condition_comparison[f'{metric}_delta'] = condition_comparison[f'{metric}_truthseeker'] - condition_comparison[f'{metric}_llm']\n",
    "\n",
    "print('Participant-level condition means (LLM data vs TruthSeeker data):')\n",
    "display(condition_comparison.round(3))\n",
    "\n",
    "condition_long = condition_comparison[[\n",
    "    'Participation Id',\n",
    "    'latent_mean_llm', 'latent_mean_truthseeker',\n",
    "    'recent_mean_llm', 'recent_mean_truthseeker',\n",
    "    'new_mean_llm', 'new_mean_truthseeker',\n",
    "]].melt(id_vars='Participation Id', var_name='metric_form', value_name='mean_rating')\n",
    "condition_long['condition'] = condition_long['metric_form'].apply(\n",
    "    lambda x: 'latent' if 'latent' in x else ('recent' if 'recent' in x else 'new')\n",
    ")\n",
    "condition_long['form'] = condition_long['metric_form'].apply(lambda x: 'LLM data' if x.endswith('_llm') else 'TruthSeeker data')\n",
    "\n",
    "condition_form_anova = AnovaRM(\n",
    "    condition_long.rename(columns={'Participation Id': 'participant_id'}),\n",
    "    depvar='mean_rating',\n",
    "    subject='participant_id',\n",
    "    within=['form', 'condition'],\n",
    ").fit()\n",
    "condition_form_table = condition_form_anova.anova_table.reset_index().rename(columns={'index': 'effect'})\n",
    "condition_form_table['partial_eta_sq'] = (\n",
    "    condition_form_table['F Value'] * condition_form_table['Num DF']\n",
    ") / ((condition_form_table['F Value'] * condition_form_table['Num DF']) + condition_form_table['Den DF'])\n",
    "\n",
    "condition_followup_rows = []\n",
    "condition_followup_p = []\n",
    "for condition in ['latent', 'recent', 'new']:\n",
    "    paired = condition_comparison[[f'{condition}_mean_llm', f'{condition}_mean_truthseeker']].dropna()\n",
    "    diff = paired[f'{condition}_mean_truthseeker'] - paired[f'{condition}_mean_llm']\n",
    "    t_stat, p_value = ttest_rel(paired[f'{condition}_mean_truthseeker'], paired[f'{condition}_mean_llm'])\n",
    "    condition_followup_rows.append({\n",
    "        'condition': condition.title(),\n",
    "        'n': len(paired),\n",
    "        'llm_mean': paired[f'{condition}_mean_llm'].mean(),\n",
    "        'truthseeker_mean': paired[f'{condition}_mean_truthseeker'].mean(),\n",
    "        'mean_diff_truthseeker_minus_llm': diff.mean(),\n",
    "        't': t_stat,\n",
    "        'p_raw': p_value,\n",
    "        'cohens_dz': diff.mean() / diff.std(ddof=1),\n",
    "    })\n",
    "    condition_followup_p.append(p_value)\n",
    "\n",
    "condition_followup = pd.DataFrame(condition_followup_rows)\n",
    "condition_followup['p_adj'] = multipletests(condition_followup_p, method='bonferroni')[1]\n",
    "condition_followup['significant'] = condition_followup['p_adj'] < 0.05\n",
    "\n",
    "print('Repeated-measures ANOVA: form x condition')\n",
    "display(condition_form_table.round(4))\n",
    "print('Follow-up paired tests: TruthSeeker vs LLM within each condition')\n",
    "display(condition_followup.round(4))\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(20, 6), gridspec_kw={'width_ratios': [1.35, 1]})\n",
    "\n",
    "# Left panel: paired LLM-vs-TruthSeeker comparison for each condition within each participant\n",
    "base_x = np.arange(len(condition_comparison))\n",
    "condition_offsets = {'Latent': -0.24, 'Recent': 0.0, 'New': 0.24}\n",
    "condition_colors = {'Latent': BLUE, 'Recent': GREEN, 'New': ORANGE}\n",
    "\n",
    "for condition, offset in condition_offsets.items():\n",
    "    llm_vals = condition_comparison[f'{condition.lower()}_mean_llm'].to_numpy()\n",
    "    truth_vals = condition_comparison[f'{condition.lower()}_mean_truthseeker'].to_numpy()\n",
    "    xpos = base_x + offset\n",
    "    for x0, y_llm, y_truth in zip(xpos, llm_vals, truth_vals):\n",
    "        axes[0].plot([x0, x0], [y_llm, y_truth], color=condition_colors[condition], alpha=0.45, linewidth=2)\n",
    "    axes[0].scatter(xpos, llm_vals, color=condition_colors[condition], marker='o', s=55, label=f'{condition} (LLM data)')\n",
    "    axes[0].scatter(xpos, truth_vals, color=condition_colors[condition], marker='s', s=55, label=f'{condition} (TruthSeeker data)')\n",
    "\n",
