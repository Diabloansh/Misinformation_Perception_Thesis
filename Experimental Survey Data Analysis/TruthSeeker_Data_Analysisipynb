    "fig, axes = plt.subplots(2, 3, figsize=(18, 10), sharey=True)\n",
    "\n",
    "conditions = list(df_all['condition'].cat.categories)\n",
    "\n",
    "overall_three_way_p = anova_p(inferential_results['Overall']['three_way_anova'])\n",
    "u35_three_way_p = anova_p(inferential_results['Under 35']['three_way_anova'])\n",
    "o35_three_way_p = anova_p(inferential_results['Over 35']['three_way_anova'])\n",
    "\n",
    "for col_idx, condition in enumerate(conditions):\n",
    "    overall_sub = df_all[df_all['condition'] == condition]\n",
    "    s = mean_sem(overall_sub, ['topic', 'cue_type_final'])\n",
    "    for topic in s['topic'].cat.categories:\n",
    "        sub = s[s['topic'] == topic]\n",
    "        axes[0, col_idx].errorbar(sub['cue_type_final'].astype(str), sub['mean'],\n",
    "                                  yerr=sub['sem'], marker='o', linestyle='-',\n",
    "                                  color=TOPIC_COLORS[str(topic)], capsize=5,\n",
    "                                  label=str(topic), linewidth=2)\n",
    "    axes[0, col_idx].set_title(f'Overall\\nCondition: {condition}')\n",
    "    axes[0, col_idx].set_xlabel('Cue Type')\n",
    "    axes[0, col_idx].set_ylabel('Mean Believability Rating')\n",
    "    axes[0, col_idx].set_ylim(1, 5)\n",
    "    place_legend(axes[0, col_idx], title='Topic', loc='upper right')\n",
    "    add_sig_badge(axes[0, col_idx], {'p': overall_three_way_p, 'color': COL_OVERALL})\n",
    "\n",
    "    for data, group_label in [(df_u35, 'Under 35'), (df_o35, 'Over 35')]:\n",
    "        sub_data = data[data['condition'] == condition]\n",
    "        s = mean_sem(sub_data, ['topic', 'cue_type_final'])\n",
    "        style = GROUP_STYLES[group_label]\n",
    "        for topic in s['topic'].cat.categories:\n",
    "            sub = s[s['topic'] == topic]\n",
    "            axes[1, col_idx].errorbar(sub['cue_type_final'].astype(str), sub['mean'],\n",
    "                                      yerr=sub['sem'], marker=style['marker'], linestyle=style['linestyle'],\n",
    "                                      color=TOPIC_COLORS[str(topic)], capsize=5, linewidth=2)\n",
    "\n",
    "    topic_handles = [Line2D([0], [0], color=color, marker='o', linestyle='-', linewidth=2, label=topic.title())\n",
    "                     for topic, color in TOPIC_COLORS.items()]\n",
    "    group_handles = [Line2D([0], [0], color='black', marker=style['marker'], linestyle=style['linestyle'],\n",
    "                            linewidth=2, label=label)\n",
    "                     for label, style in GROUP_STYLES.items()]\n",
    "    axes[1, col_idx].set_title(f'Under 35 vs Over 35\\nCondition: {condition}')\n",
    "    axes[1, col_idx].set_xlabel('Cue Type')\n",
    "    axes[1, col_idx].set_ylabel('Mean Believability Rating')\n",
    "    axes[1, col_idx].set_ylim(1, 5)\n",
    "    place_legend(axes[1, col_idx], handles=topic_handles + group_handles,\n",
    "                 title='Color = Topic, Style = Group', loc='upper right')\n",
    "    add_sig_badge(axes[1, col_idx], [\n",
    "        {'label': 'U35', 'p': u35_three_way_p, 'color': COL_U35},\n",
    "        {'label': 'O35', 'p': o35_three_way_p, 'color': COL_O35},\n",
    "    ])\n",
    "\n",
    "plt.suptitle('Topic x Condition x Cue Type', fontsize=16, y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
