   "source": [
    "OLD_DATA_PATH = Path('selected_24_long_dataset.csv')\n",
    "\n",
    "old_form = pd.read_csv(OLD_DATA_PATH)\n",
    "\n",
    "for data in (old_form,):\n",
    "    data['Participation Id'] = pd.to_numeric(data['Participation Id'], errors='coerce')\n",
    "    data['believability_rating'] = pd.to_numeric(data['believability_rating'], errors='coerce')\n",
    "    data['Age'] = pd.to_numeric(data['Age'], errors='coerce')\n",
    "\n",
    "old_form = old_form.dropna(subset=['Participation Id', 'believability_rating', 'text', 'topic', 'condition', 'cue_type_final']).copy()\n",
    "old_form['Participation Id'] = old_form['Participation Id'].astype(int)\n",
    "\n",
    "overlap_pids = sorted(set(df_all['Participation Id']).intersection(set(old_form['Participation Id'])))\n",
    "llm_overlap = old_form[old_form['Participation Id'].isin(overlap_pids)].copy()\n",
    "truthseeker_overlap = df_all[df_all['Participation Id'].isin(overlap_pids)].copy()\n",
    "\n",
    "def pattern_label(a, b, a_label, b_label, tol=0.05):\n",
    "    if pd.isna(a) or pd.isna(b):\n",
    "        return 'insufficient data'\n",
    "    if abs(a - b) <= tol:\n",
    "        return f'no clear pattern ({a_label}~{b_label})'\n",
    "    return f'{a_label} > {b_label}' if a > b else f'{b_label} > {a_label}'\n",
    "\n",
    "def rank_label(values):\n",
    "    items = [(k, v) for k, v in values.items() if not pd.isna(v)]\n",
    "    items = sorted(items, key=lambda kv: (-kv[1], kv[0]))\n",
    "    return ' > '.join(k for k, _ in items)\n",
    "\n",
    "def direction_label(value, positive_label, negative_label, tol=0.05):\n",
    "    if pd.isna(value):\n",
    "        return 'missing'\n",
    "    if abs(value) <= tol:\n",
    "        return 'tie'\n",
    "    return positive_label if value > 0 else negative_label\n",
    "\n",
    "def participant_profiles(data, form_label):\n",
    "    rows = []\n",
    "    for pid, sub in data.groupby('Participation Id'):\n",
    "        overall = sub['believability_rating'].mean()\n",
    "        topic_means = sub.groupby('topic')['believability_rating'].mean()\n",
    "        cue_means = sub.groupby('cue_type_final')['believability_rating'].mean()\n",
    "        cond_means = sub.groupby('condition')['believability_rating'].mean()\n",
    "\n",
    "        rows.append({\n",
    "            'Participation Id': pid,\n",
    "            'form': form_label,\n",
    "            'Age': sub['Age'].iloc[0],\n",
    "            'overall_mean': overall,\n",
    "            'health_mean': topic_means.get('health', np.nan),\n",
    "            'technology_mean': topic_means.get('technology', np.nan),\n",
    "            'topic_pattern': pattern_label(topic_means.get('health', np.nan), topic_means.get('technology', np.nan), 'health', 'tech'),\n",
    "            'central_mean': cue_means.get('central', np.nan),\n",
    "            'peripheral_mean': cue_means.get('peripheral', np.nan),\n",
    "            'cue_pattern': pattern_label(cue_means.get('central', np.nan), cue_means.get('peripheral', np.nan), 'central', 'peripheral'),\n",
    "            'latent_mean': cond_means.get('latent', np.nan),\n",
    "            'recent_mean': cond_means.get('recent', np.nan),\n",
    "            'new_mean': cond_means.get('new', np.nan),\n",
    "            'condition_rank': rank_label({\n",
    "                'latent': cond_means.get('latent', np.nan),\n",
    "                'recent': cond_means.get('recent', np.nan),\n",
    "                'new': cond_means.get('new', np.nan),\n",
    "            }),\n",
    "        })\n",
    "    return pd.DataFrame(rows)\n",
    "\n",
    "llm_profiles = participant_profiles(llm_overlap, 'LLM data')\n",
    "truthseeker_profiles = participant_profiles(truthseeker_overlap, 'TruthSeeker data')\n",
    "\n",
    "comparison = llm_profiles.merge(truthseeker_profiles, on='Participation Id', suffixes=('_llm', '_truthseeker')).sort_values('Participation Id')\n",
    "\n",
    "pattern_comparison = comparison[[\n",
    "    'Participation Id',\n",
    "    'overall_mean_llm', 'overall_mean_truthseeker',\n",
    "    'topic_pattern_llm', 'topic_pattern_truthseeker',\n",
    "    'cue_pattern_llm', 'cue_pattern_truthseeker',\n",
    "    'condition_rank_llm', 'condition_rank_truthseeker',\n",
    "]].copy()\n",
    "pattern_comparison = pattern_comparison.rename(columns={\n",
    "    'overall_mean_llm': 'overall_mean_LLM_data',\n",
    "    'overall_mean_truthseeker': 'overall_mean_TruthSeeker_data',\n",
    "    'topic_pattern_llm': 'topic_pattern_LLM_data',\n",
    "    'topic_pattern_truthseeker': 'topic_pattern_TruthSeeker_data',\n",
    "    'cue_pattern_llm': 'cue_pattern_LLM_data',\n",
    "    'cue_pattern_truthseeker': 'cue_pattern_TruthSeeker_data',\n",
    "    'condition_rank_llm': 'condition_rank_LLM_data',\n",
    "    'condition_rank_truthseeker': 'condition_rank_TruthSeeker_data',\n",
    "})\n",
    "\n",
    "delta_comparison = comparison[[\n",
    "    'Participation Id',\n",
    "    'health_mean_llm', 'health_mean_truthseeker',\n",
    "    'technology_mean_llm', 'technology_mean_truthseeker',\n",
    "    'central_mean_llm', 'central_mean_truthseeker',\n",
    "    'peripheral_mean_llm', 'peripheral_mean_truthseeker',\n",
    "    'latent_mean_llm', 'latent_mean_truthseeker',\n",
    "    'recent_mean_llm', 'recent_mean_truthseeker',\n",
    "    'new_mean_llm', 'new_mean_truthseeker',\n",
    "]].copy()\n",
    "\n",
    "for metric in ['health_mean', 'technology_mean', 'central_mean', 'peripheral_mean', 'latent_mean', 'recent_mean', 'new_mean']:\n",
    "    delta_comparison[f'{metric}_delta'] = delta_comparison[f'{metric}_truthseeker'] - delta_comparison[f'{metric}_llm']\n",
    "\n",
    "print(f'Overlapping participants compared across datasets: {len(overlap_pids)}')\n",
    "display(pattern_comparison.round(3))\n",
    "display(delta_comparison.round(3))\n",
    "\n",
    "paired_metric_specs = [\n",
    "    ('overall_mean', 'Overall mean'),\n",
    "    ('health_mean', 'Health mean'),\n",
    "    ('technology_mean', 'Technology mean'),\n",
    "    ('central_mean', 'Central mean'),\n",
    "    ('peripheral_mean', 'Peripheral mean'),\n",
    "]\n",
    "\n",
    "paired_rows = []\n",
    "paired_p_values = []\n",
    "for metric_key, metric_label in paired_metric_specs:\n",
    "    paired = comparison[[f'{metric_key}_llm', f'{metric_key}_truthseeker']].dropna()\n",
    "    diff = paired[f'{metric_key}_truthseeker'] - paired[f'{metric_key}_llm']\n",
    "    t_stat, p_value = ttest_rel(paired[f'{metric_key}_truthseeker'], paired[f'{metric_key}_llm'])\n",
    "    paired_rows.append({\n",
    "        'metric': metric_label,\n",
    "        'n': len(paired),\n",
    "        'llm_mean': paired[f'{metric_key}_llm'].mean(),\n",
    "        'truthseeker_mean': paired[f'{metric_key}_truthseeker'].mean(),\n",
    "        'mean_diff_truthseeker_minus_llm': diff.mean(),\n",
    "        't': t_stat,\n",
    "        'p_raw': p_value,\n",
    "        'cohens_dz': diff.mean() / diff.std(ddof=1),\n",
    "    })\n",
    "    paired_p_values.append(p_value)\n",
    "\n",
    "paired_participant_tests = pd.DataFrame(paired_rows)\n",
    "paired_participant_tests['p_adj'] = multipletests(paired_p_values, method='bonferroni')[1]\n",
    "paired_participant_tests['significant'] = paired_participant_tests['p_adj'] < 0.05\n",
    "\n",
    "print('Paired participant-level tests (TruthSeeker vs LLM):')\n",
    "display(paired_participant_tests.round(4))\n",
    "\n",
    "topic_llm_label = comparison['health_mean_llm'].sub(comparison['technology_mean_llm']).apply(\n",
    "    lambda x: direction_label(x, 'health > tech', 'tech > health')\n",
    ")\n",
    "topic_truth_label = comparison['health_mean_truthseeker'].sub(comparison['technology_mean_truthseeker']).apply(\n",
    "    lambda x: direction_label(x, 'health > tech', 'tech > health')\n",
    ")\n",
    "cue_llm_label = comparison['central_mean_llm'].sub(comparison['peripheral_mean_llm']).apply(\n",
    "    lambda x: direction_label(x, 'central > peripheral', 'peripheral > central')\n",
    ")\n",
    "cue_truth_label = comparison['central_mean_truthseeker'].sub(comparison['peripheral_mean_truthseeker']).apply(\n",
    "    lambda x: direction_label(x, 'central > peripheral', 'peripheral > central')\n",
    ")\n",
    "\n",
    "pattern_agreement_rows = []\n",
    "for label_name, llm_labels, truth_labels, llm_diff, truth_diff in [\n",
    "    ('Topic preference', topic_llm_label, topic_truth_label,\n",
    "     comparison['health_mean_llm'] - comparison['technology_mean_llm'],\n",
    "     comparison['health_mean_truthseeker'] - comparison['technology_mean_truthseeker']),\n",
    "    ('Cue preference', cue_llm_label, cue_truth_label,\n",
    "     comparison['central_mean_llm'] - comparison['peripheral_mean_llm'],\n",
    "     comparison['central_mean_truthseeker'] - comparison['peripheral_mean_truthseeker']),\n",
    "]:\n",
    "    exact_match = llm_labels == truth_labels\n",
    "    directional_mask = (~llm_labels.isin(['tie', 'missing'])) & (~truth_labels.isin(['tie', 'missing']))\n",
    "    directional_matches = (llm_labels[directional_mask] == truth_labels[directional_mask])\n",
    "    if directional_mask.sum() > 0:\n",
    "        directional_p = binomtest(directional_matches.sum(), n=directional_mask.sum(), p=0.5, alternative='greater').pvalue\n",
    "    else:\n",
    "        directional_p = np.nan\n",
    "    rho, rho_p = spearmanr(llm_diff, truth_diff)\n",
    "    pattern_agreement_rows.append({\n",
    "        'pattern': label_name,\n",
    "        'n': len(exact_match),\n",
    "        'exact_agreement_prop': exact_match.mean(),\n",
    "        'directional_n': directional_mask.sum(),\n",
    "        'directional_agreement_prop': directional_matches.mean() if directional_mask.sum() else np.nan,\n",
    "        'cohens_kappa': cohen_kappa_score(llm_labels, truth_labels),\n",
    "        'binomial_p_directional': directional_p,\n",
    "        'spearman_rho': rho,\n",
    "        'spearman_p': rho_p,\n",
    "    })\n",
    "\n",
    "pattern_agreement_summary = pd.DataFrame(pattern_agreement_rows)\n",
    "print('Pattern agreement summary across datasets:')\n",
    "display(pattern_agreement_summary.round(4))\n",
    "\n",
    "condition_pair_rows = []\n",
    "for left, right in [('latent', 'recent'), ('latent', 'new'), ('recent', 'new')]:\n",
    "    llm_labels = (comparison[f'{left}_mean_llm'] - comparison[f'{right}_mean_llm']).apply(\n",
    "        lambda x: direction_label(x, f'{left} > {right}', f'{right} > {left}')\n",
    "    )\n",
    "    truth_labels = (comparison[f'{left}_mean_truthseeker'] - comparison[f'{right}_mean_truthseeker']).apply(\n",
    "        lambda x: direction_label(x, f'{left} > {right}', f'{right} > {left}')\n",
    "    )\n",
    "    exact_match = llm_labels == truth_labels\n",
    "    directional_mask = (~llm_labels.isin(['tie', 'missing'])) & (~truth_labels.isin(['tie', 'missing']))\n",
    "    directional_matches = (llm_labels[directional_mask] == truth_labels[directional_mask])\n",
    "    if directional_mask.sum() > 0:\n",
    "        directional_p = binomtest(directional_matches.sum(), n=directional_mask.sum(), p=0.5, alternative='greater').pvalue\n",
    "    else:\n",
    "        directional_p = np.nan\n",
    "    condition_pair_rows.append({\n",
    "        'comparison': f'{left} vs {right}',\n",
    "        'n': len(exact_match),\n",
    "        'exact_agreement_prop': exact_match.mean(),\n",
    "        'directional_n': directional_mask.sum(),\n",
    "        'directional_agreement_prop': directional_matches.mean() if directional_mask.sum() else np.nan,\n",
    "        'cohens_kappa': cohen_kappa_score(llm_labels, truth_labels),\n",
    "        'binomial_p_directional': directional_p,\n",
    "    })\n",
    "\n",
    "condition_pair_agreement = pd.DataFrame(condition_pair_rows)\n",
    "comparison['condition_rank_llm_full'] = comparison.apply(\n",
    "    lambda row: rank_label({'latent': row['latent_mean_llm'], 'recent': row['recent_mean_llm'], 'new': row['new_mean_llm']}),\n",
    "    axis=1,\n",
    ")\n",
    "comparison['condition_rank_truth_full'] = comparison.apply(\n",
    "    lambda row: rank_label({'latent': row['latent_mean_truthseeker'], 'recent': row['recent_mean_truthseeker'], 'new': row['new_mean_truthseeker']}),\n",
    "    axis=1,\n",
    ")\n",
    "condition_rank_agreement = pd.DataFrame([{\n",
    "    'pattern': 'Full condition rank',\n",
    "    'n': len(comparison),\n",
    "    'exact_agreement_prop': (comparison['condition_rank_llm_full'] == comparison['condition_rank_truth_full']).mean(),\n",
    "    'cohens_kappa': cohen_kappa_score(comparison['condition_rank_llm_full'], comparison['condition_rank_truth_full']),\n",
    "}])\n",
    "print('Condition-pattern agreement across datasets:')\n",
    "display(condition_pair_agreement.round(4))\n",
    "display(condition_rank_agreement.round(4))\n",
    "\n",
    "plot_data = pd.concat([\n",
    "    llm_profiles[['Participation Id', 'overall_mean']].assign(form='LLM data'),\n",
    "    truthseeker_profiles[['Participation Id', 'overall_mean']].assign(form='TruthSeeker data'),\n",
    "], ignore_index=True)\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(22, 12), gridspec_kw={'width_ratios': [1, 1.2]})\n",
    "\n",
    "sns.pointplot(data=plot_data, x='Participation Id', y='overall_mean', hue='form',\n",
    "              dodge=0.3, markers=['o', 's'], linestyles=['-', '--'], ax=axes[0, 0])\n",
    "axes[0, 0].set_title('Participant Overall Mean: LLM Data vs TruthSeeker Data')\n",
    "axes[0, 0].set_xlabel('Participant ID')\n",
    "axes[0, 0].set_ylabel('Mean Believability Rating')\n",
    "axes[0, 0].set_ylim(0.5, 5.5)\n",
    "axes[0, 0].tick_params(axis='x', rotation=35)\n",
    "place_legend(axes[0, 0], title='Dataset', loc='upper right')\n",
    "\n",
    "# Topic paired comparison\n",
    "base_x = np.arange(len(comparison))\n",
    "topic_offsets = {'Health': -0.14, 'Technology': 0.14}\n",
    "topic_colors = {'Health': BLUE, 'Technology': ORANGE}\n",
    "for topic, offset in topic_offsets.items():\n",
    "    llm_vals = comparison[f'{topic.lower()}_mean_llm'].to_numpy()\n",
    "    truth_vals = comparison[f'{topic.lower()}_mean_truthseeker'].to_numpy()\n",
    "    xpos = base_x + offset\n",
    "    for x0, y_llm, y_truth in zip(xpos, llm_vals, truth_vals):\n",
    "        axes[0, 1].plot([x0, x0], [y_llm, y_truth], color=topic_colors[topic], alpha=0.45, linewidth=2)\n",
    "    axes[0, 1].scatter(xpos, llm_vals, color=topic_colors[topic], marker='o', s=55, label=f'{topic} (LLM data)')\n",
    "    axes[0, 1].scatter(xpos, truth_vals, color=topic_colors[topic], marker='s', s=55, label=f'{topic} (TruthSeeker data)')\n",
    "axes[0, 1].set_title('Participant Topic Means: LLM Data vs TruthSeeker Data')\n",
    "axes[0, 1].set_xlabel('Participant ID')\n",
    "axes[0, 1].set_ylabel('Mean Believability Rating')\n",
    "axes[0, 1].set_xticks(base_x)\n",
    "axes[0, 1].set_xticklabels(comparison['Participation Id'].tolist(), rotation=35)\n",
    "axes[0, 1].set_ylim(0.5, 5.5)\n",
    "axes[0, 1].legend(title='Topic and Dataset', bbox_to_anchor=(1.02, 1), loc='upper left', frameon=True, fontsize=8, title_fontsize=9)\n",
    "\n",
    "# Cue paired comparison\n",
    "cue_offsets = {'Central': -0.14, 'Peripheral': 0.14}\n",
    "cue_colors = {'Central': GREEN, 'Peripheral': '#e76f51'}\n",
    "for cue, offset in cue_offsets.items():\n",
    "    llm_vals = comparison[f'{cue.lower()}_mean_llm'].to_numpy()\n",
    "    truth_vals = comparison[f'{cue.lower()}_mean_truthseeker'].to_numpy()\n",
    "    xpos = base_x + offset\n",
    "    for x0, y_llm, y_truth in zip(xpos, llm_vals, truth_vals):\n",
    "        axes[1, 0].plot([x0, x0], [y_llm, y_truth], color=cue_colors[cue], alpha=0.45, linewidth=2)\n",
    "    axes[1, 0].scatter(xpos, llm_vals, color=cue_colors[cue], marker='o', s=55, label=f'{cue} (LLM data)')\n",
    "    axes[1, 0].scatter(xpos, truth_vals, color=cue_colors[cue], marker='s', s=55, label=f'{cue} (TruthSeeker data)')\n",
    "axes[1, 0].set_title('Participant Cue Means: LLM Data vs TruthSeeker Data')\n",
